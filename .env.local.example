# Backend network configuration
HOST=localhost
PORT=8787

# GitHub API configuration for backend
GITHUB_API_URL=https://api.github.com/graphql
GITHUB_DEFAULT_USERNAME=your_github_username
GITHUB_TOKEN=replace_with_your_token

# Frontend runtime configuration
VITE_API_PROXY_TARGET=http://localhost:8787
VITE_GITHUB_USERNAME=your_github_username
VITE_GITHUB_CONTRIBUTIONS_ENDPOINT=/api/github/contributions
VITE_GITHUB_POLL_INTERVAL_MS=120000
